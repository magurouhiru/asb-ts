// https://containers.dev/implementors/json_reference/
{
  // https://containers.dev/implementors/json_reference/#general-properties
  "name": "ASB-ts-devcontainer",
  "forwardPorts": [5174],
  "portsAttributes": {
    "5174": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  // "otherPortsAttributes": {},
  // "containerEnv": {},
  // "remoteEnv": {},
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "updateRemoteUserUID": true,
  // "userEnvProbe": "none",
  // "overrideCommand ": false,
  // "shutdownAction": "none",
  // "init": false,
  // "privileged": false,
  // "capAdd": [],
  // "securityOpt": [],
  "mounts": [
    {
      // node_modulesをホストと分離
      "source": "ASB-ts-devcontainer__node_modules",
      "target": "/home/vscode/app/node_modules",
      "type": "volume"
    },
    {
      // .pnpm-storeをホストと分離
      "source": "ASB-ts-devcontainer__.pnpm-store",
      "target": "/home/vscode/app/.pnpm-store",
      "type": "volume"
    }
  ],
  "features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    "ghcr.io/devcontainers/features/node:2": {
      "version": 22,
      "pnpmVersion": 11
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:4": {}
  },
  // "overrideFeatureInstallOrder": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "github.vscode-github-actions",
        "ms-vscode.makefile-tools",
        "saoudrizwan.claude-dev",
        "vitest.explorer"
      ],
      "settings": {
        "npm.packageManager": "pnpm",
        "npm.scriptRunner": "node",
        // フォーマットはBiome
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[html]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[css]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "editor.formatOnSave": true
      }
    }
  },
  // https://containers.dev/implementors/json_reference/#image-specific
  // "image": "mcr.microsoft.com/devcontainers/base:debian",
  // "build": {
  //   "dockerfile": "Dockerfile",
  //   "context": ".",
  //   "args": {},
  //   "options": [],
  //   "target": "",
  //   "cacheFrom": []
  // },
  // "appPort": [],
  // "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/app,type=bind,consistency=cached",
  // "workspaceFolder": "/home/vscode/app",
  // "runArgs": [
  //   "--cap-add=SYS_PTRACE",
  //   "--security-opt",
  //   "seccomp=unconfined",
  //   "--name",
  //   "ASB-web-devcontainer",
  //   "--hostname",
  //   "dotnet"
  // ],
  // https://containers.dev/implementors/json_reference/#compose-specific
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "runServices": [],
  "workspaceFolder": "/home/vscode/app",
  // https://containers.dev/implementors/json_reference/#lifecycle-scripts
  // "initializeCommand":[],
  // "onCreateCommand": [],
  // "updateContentCommand": [],
  // "postCreateCommand": [],
  "postStartCommand": {
    // 権限問題を回避
    "chown": "sudo chown -R vscode:vscode /home/vscode/app",
    "pnpm ci": "pnpm i",
    // "ollama pull gemma4": "curl http://ollama:11434/api/pull -d '{\"model\": \"gemma4:e4b\", \"stream\": false}'",
    "install act via": "gh extension install https://github.com/nektos/gh-act"
  }
  // "postAttachCommand": [],
  // "waitFor": "updateContentCommand"
}
