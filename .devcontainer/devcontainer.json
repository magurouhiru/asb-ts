// https://containers.dev/implementors/json_reference/
{
  // https://containers.dev/implementors/json_reference/#general-properties
  "name": "ASB-web-devcontainer",
  "forwardPorts": [5174],
  "portsAttributes": {
    "5174": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  // "otherPortsAttributes": {},
  // "containerEnv": {},
  // "remoteEnv": {},
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "updateRemoteUserUID": true,
  // "userEnvProbe": "none",
  // "overrideCommand ": false,
  // "shutdownAction": "none",
  // "init": false,
  // "privileged": false,
  // "capAdd": [],
  // "securityOpt": [],
  "mounts": [
    {
      // node_modulesをホストと分離
      "source": "ASB-web-devcontainer__node_modules",
      "target": "/home/vscode/app/node_modules",
      "type": "volume"
    }
  ],
  // "features": {},
  // "overrideFeatureInstallOrder": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "github.vscode-github-actions",
        "ms-vscode.makefile-tools",
        "saoudrizwan.claude-dev",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "npm.packageManager": "bun",
        "npm.scriptRunner": "bun",
        // フォーマットはBiome
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[html]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[css]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "editor.formatOnSave": true,
        // なんか拡張機能が動かないので、直接パスを指定してみる
        "biome.lsp.bin": "/home/vscode/app/node_modules/.bun/@biomejs+cli-linux-x64@2.4.10/node_modules/@biomejs/cli-linux-x64/biome"
      }
    }
  },
  // https://containers.dev/implementors/json_reference/#image-specific
  // "image": "mcr.microsoft.com/devcontainers/base:debian",
  // "build": {
  //   "dockerfile": "Dockerfile",
  //   "context": ".",
  //   "args": {},
  //   "options": [],
  //   "target": "",
  //   "cacheFrom": []
  // },
  // "appPort": [],
  // "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/app,type=bind,consistency=cached",
  // "workspaceFolder": "/home/vscode/app",
  // "runArgs": [
  //   "--cap-add=SYS_PTRACE",
  //   "--security-opt",
  //   "seccomp=unconfined",
  //   "--name",
  //   "ASB-web-devcontainer",
  //   "--hostname",
  //   "dotnet"
  // ],
  // https://containers.dev/implementors/json_reference/#compose-specific
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "runServices": [],
  "workspaceFolder": "/home/vscode/app",
  // https://containers.dev/implementors/json_reference/#lifecycle-scripts
  // "initializeCommand":[],
  // "onCreateCommand": [],
  // "updateContentCommand": [],
  // "postCreateCommand": [],
  "postStartCommand": {
    // 権限問題を回避
    "chown": "sudo chown -R vscode:vscode /home/vscode/app",
    "bun ci": "bun ci",
    "build asb-ts": "bun build:asb-ts",
    "ollama pull gemma4": "curl http://ollama:11434/api/pull -d '{\"model\": \"gemma4:e4b\", \"stream\": false}'"
  }
  // "postAttachCommand": [],
  // "waitFor": "updateContentCommand"
}
