{
  "name": "asb-web-workspace",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "2.4.15",
      "fuse.js": "^7.2.0",
      "typescript": "~6.0.2",
      "valibot": "^1.3.0",
      "license-checker-rseidelsohn": "^4.4.2",
      "vitest": "^4.1.2"
    }
  },
  "scripts": {
    "build": "bun build:asb-ts && bun build:asb-web",
    "build:asb-ts": "bun --filter asb-ts build",
    "build:asb-web": "bun --filter asb-web build",
    "test": "bun test:asb-ts",
    "test:asb-ts": "bun --filter asb-ts test",
    "biome": "biome check .",
    "biome:fix": "biome check --write --unsafe ."
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:"
  }
}
