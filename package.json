{
  "name": "@asb-ts/workspace",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "2.4.15",
      "@types/bun": "^1.3.14",
      "fuse.js": "^7.2.0",
      "typescript": "~6.0.2",
      "valibot": "^1.3.0",
      "remeda": "^2.38.0",
      "license-checker-rseidelsohn": "^4.4.2"
    }
  },
  "scripts": {
    "build": "bun build:apps",
    "build:apps": "bun --filter ./apps/* build",
    "test": "bun test:packages",
    "test:packages": "bun --filter ./packages/* test",
    "biome": "biome check .",
    "biome:fix": "biome check --write --unsafe ."
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:"
  }
}
