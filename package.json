{
  "name": "@asb-ts/workspace",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "pnpm build:apps",
    "build:apps": "pnpm build:apps:web",
    "build:apps:web": "pnpm --filter ./apps/web build",
    "test": "pnpm test:packages",
    "test:packages": "pnpm --filter ./packages/* test",
    "biome": "biome check .",
    "biome:fix": "biome check --write --unsafe ."
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "vitest": "catalog:"
  }
}
