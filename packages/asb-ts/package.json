{
  "name": "asb-ts",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "test": "vitest run --dir src",
    "biome": "biome check .",
    "biome:fix": "biome check --write --unsafe .",
    "tools": "bun run tools:create-values && bun run tools:create-name-dict && bun run tools:create-variants-default-unselected",
    "tools:create-values": "bun run ./tools/create-values.ts && bun run biome:fix",
    "tools:create-name-dict": "bun run ./tools/create-name-dict.ts && bun run biome:fix",
    "tools:create-variants-default-unselected": "bun run ./tools/create-variants-default-unselected.ts && bun run biome:fix",
    "license:gen": "bun x license-checker-rseidelsohn > ./THIRD_PARTY_LICENSES.txt"
  },
  "dependencies": {
    "fuse.js": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "license-checker-rseidelsohn": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
